# Ensure index.php is the default file and takes priority over index.html
DirectoryIndex index.php index.html

# Prevent directory listing
Options -Indexes

# Handle MIME types correctly
<IfModule mod_mime.c>
    AddType text/css .css
    AddType application/javascript .js
</IfModule>

# Redirect index.html to index.php to clear old React artifacts
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # If index.html is requested, redirect to index.php
    RewriteRule ^index\.html$ /index.php [R=301,L]
    
    # If index.css is requested but missing, don't return HTML
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule \.css$ - [R=404,L]
</IfModule>
